# Copy to ".env" and fill in. Never commit the real .env (it is gitignored).
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# USUM_MODEL=claude-sonnet-4-6
# USUM_WHISPER_MODEL=base

# OneNote push (only needed with --onenote). See README "Push to OneNote".
# USUM_MS_CLIENT_ID=00000000-0000-0000-0000-000000000000
# USUM_MS_TENANT=common
